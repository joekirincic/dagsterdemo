FROM python:3.12-slim

RUN pip install \
    dagster \
    dagster-postgres \
    dagster-docker

# Install system dependencies for R
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    g++ \
    gcc \
    gfortran \
    make \
    libbz2-dev \
    libcairo2-dev \
    libcurl4-openssl-dev \
    libdeflate-dev \
    libicu-dev \
    liblzma-dev \
    libopenblas-dev \
    libpango1.0-dev \
    libpcre2-dev \
    libpng-dev \
    libreadline-dev \
    libtiff-dev \
    libtirpc-dev \
    libx11-dev \
    libxt-dev \
    libzstd-dev \
    zlib1g-dev \
    tcl-dev \
    tk-dev && \
    rm -rf /var/lib/apt/lists/*

# Install rig for R installation management
RUN curl -Ls https://github.com/r-lib/rig/releases/download/latest/rig-linux-arm64-latest.tar.gz | \
    tar xz -C /usr/local && \
    chmod +x /usr/local/bin/rig

# Install latest stable R using rig
RUN rig add release && \
    rig system add-pak

RUN R -e "pak::pak(c('joekirincic/dagsterpipes', 'DBI', 'RPostgres'))"

# Add code location code
WORKDIR /opt/dagster/app
COPY dagsterdemo/ /opt/dagster/app/dagsterdemo
COPY dagsterdemo_tests/ /opt/dagster/app/dagsterdemo_tests

# Run dagster code server on port 4000
EXPOSE 4000

# CMD allows this to be overridden from run launchers or executors to execute runs and steps
CMD ["dagster", "code-server", "start", "-h", "0.0.0.0", "-p", "4000", "-f", "dagsterdemo/definitions.py"]